# PostgreSQL (yerel: Docker, üretim: Neon / Supabase / Vercel Postgres)
#
# Neon + Prisma: konsolda iki dize kopyalayın (Prisma dokümantasyonu):
#   DATABASE_URL = havuzlu (-pooler) …?sslmode=require&pgbouncer=true
#   DIRECT_URL   = doğrudan (pooler olmayan) …?sslmode=require
# Tek doğrudan dizeniz varsa ikisine de aynı değeri verin.
# &channel_binding=require Prisma ile sorun çıkarabiliyor — kullanmayın.
# Şifrede @ # % : / ? gibi karakterler varsa kullanıcı adı/şifre kısmını URL-encode edin.
#
# Vercel: değerleri TIRNAKSIZ yapıştırın; Production (ve gerekirse Preview) için tanımlayın.
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/careofy
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/careofy

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
ANTHROPIC_API_KEY=""
